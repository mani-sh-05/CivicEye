{
  "name": "civiceye-functions",
  "description": "CivicEye Firebase Cloud Functions – Location + AI Verification",
  "scripts": {
    "lint":   "eslint .",
    "serve":  "firebase emulators:start --only functions",
    "shell":  "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs":   "firebase functions:log"
  },
  "engines": { "node": "18" },
  "main": "index.js",
  "dependencies": {
    "firebase-admin":     "^12.0.0",
    "firebase-functions": "^5.0.0",
    "geolib":             "^3.3.4",
    "node-fetch":         "^3.3.2"
  },
  "devDependencies": {
    "eslint":             "^8.15.0",
    "eslint-config-google":"^0.14.0"
  },
  "private": true
}
